# ================================================
# SolNuv Frontend - Environment Variables
# Copy this to .env.local and fill in your values
# ================================================

# Supabase (same project as backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL
NEXT_PUBLIC_API_URL=https://api.solnuv.com

# Paystack Public Key (safe to expose)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-public-key

# App URL
NEXT_PUBLIC_APP_URL=https://solnuv.com
