{
  "name": "solnuv-backend",
  "version": "1.0.0",
  "description": "SolNuv - Solar E-Waste Tracking & Compliance Platform API",
  "main": "src/server.ts",
  "scripts": {
    "build": "npm run typecheck && npm run build:render && node scripts/render-build.cjs",
    "build:render": "tsc --project tsconfig.json --noEmit false --outDir dist",
    "start": "tsx src/server.ts",
    "dev": "nodemon --exec tsx src/server.ts",
    "lint": "eslint src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "test:nerc-regression": "tsx scripts/nerc-regression-smoke.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.15.0",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.0.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
