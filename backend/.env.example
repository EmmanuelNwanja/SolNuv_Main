# ================================================
# SolNuv Backend - Environment Variables
# Copy this to .env and fill in your values
# ================================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://solnuv.com

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT Secret (generate a random 64-char string)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Brevo (formerly Sendinblue) - get from brevo.com → SMTP & API
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-login-email@email.com
BREVO_SMTP_PASS=your-brevo-smtp-password
EMAIL_FROM=noreply@solnuv.com
EMAIL_FROM_NAME=SolNuv Platform

# Paystack (get from paystack.com → Settings → API Keys)
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# NESREA (when available - future integration)
NESREA_EMAIL=compliance@nesrea.gov.ng
NESREA_PORTAL_URL=https://portal.nesrea.gov.ng

# Silver price (update weekly or automate)
SILVER_PRICE_USD_PER_GRAM=0.96
USD_TO_NGN_RATE=1620

# Admin (platform super admin)
PLATFORM_ADMIN_EMAIL=admin@solnuv.com

# Cron (for GitHub Actions - leave empty if using node-cron)
CRON_SECRET=your-cron-secret-here

# V2 Oracle (chain/custodian adapters)
V2_CHAIN_PROVIDER=simulated
V2_CHAIN_ID=sim-chain
V2_CUSTODIAN_PROVIDER=simulated
V2_CHAIN_ATTESTATION_URL=
V2_CHAIN_ATTESTATION_API_KEY=
V2_CUSTODIAN_WEBHOOK_URL=
V2_CUSTODIAN_WEBHOOK_SECRET=
V2_CUSTODIAN_CALLBACK_SECRET=
