{
  "private": true,
  "scripts": {
    "postinstall": "cd frontend && npm install --legacy-peer-deps",
    "build": "cd frontend && npm run build",
    "smoke:headers": "node scripts/smoke-check-headers.mjs",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "typecheck:backend": "cd backend && npm run typecheck",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "gate:ts-migration": "npm run typecheck",
    "gate:rollout": "npm run typecheck && npm run smoke:headers"
  },
  "dependencies": {
    "docker": "^1.0.0"
  }
}
